# LaunchGuard — env variable template (NO SECRET VALUES)
# Copy to venv/.env and fill in real values.
# venv/.env is gitignored — secrets never enter the repo.
# Load with: load_dotenv(Path(__file__).parent / "venv" / ".env")
# or shell: set -a; source venv/.env; set +a

# ---------------------------------------------------------------------------
# Kaggle API (original capstone env — keep for compatibility)
# ---------------------------------------------------------------------------
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=KGAT_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Gemini / Google AI (LaunchGuard agent — required for any model call)
# Get key: https://aistudio.google.com/app/apikey
# ---------------------------------------------------------------------------
GOOGLE_API_KEY=your_google_api_key_here

# ---------------------------------------------------------------------------
# GitHub (open_pr tool — needed to create fix-PRs via GitHub MCP)
# Scope: repo (read+write to a single target repo is sufficient)
# Create at: https://github.com/settings/tokens
# ---------------------------------------------------------------------------
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# open_pr mode: "mock" (default — offline dry-run, renders PR preview to eval/pr_preview/)
# or "real" (live GitHub PR creation; requires GITHUB_TOKEN; deferred to a network machine).
# Leave unset/mock for the offline demo + CI.
LAUNCHGUARD_PR_MODE=mock

# ---------------------------------------------------------------------------
# PostgreSQL + pgvector (per-project gotcha memory + eval substrate)
# Start the container: make db-up
# Default credentials match infra/docker/docker-compose.dev.yml
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://launchguard:launchguard@localhost:5432/launchguard_memory

# ---------------------------------------------------------------------------
# GCP Application Default Credentials (ADC)
# LIVE/RECORD MODE ONLY — NOT needed for the offline fixture-based demo.
# Run once: gcloud auth application-default login
# This sets credentials at ~/.config/gcloud/application_default_credentials.json.
# The LaunchGuard agent detects ADC automatically via google-auth; no env var needed.
# GCP usage is READ-ONLY (describe/list/get-iam-policy); agent never mutates live GCP.
# ---------------------------------------------------------------------------
# GCP ADC: use 'gcloud auth application-default login' for live/record mode only.
# GCP_PROJECT_ID=your-gcp-project-id
